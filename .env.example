# Banco de dados (Supabase / PostgreSQL)
DATABASE_URL=postgresql://usuario:senha@host:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://usuario:senha@host:5432/postgres
SUPABASE_URL=https://seu-projeto.supabase.co

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS (separe múltiplas origens com vírgula)
ALLOWED_ORIGINS=http://localhost:3000,https://seu-app.vercel.app

# G-Click
GCLICK_CLIENT_ID=seu_client_id
GCLICK_CLIENT_SECRET=seu_client_secret

# Zappy
ZAPPY_API_KEY=seu_token_aqui
ZAPPY_BASE_URL=https://api-suaempresa.zapcontabil.chat

# Asaas — Conta 1
ASAAS_SECRET_1=seu_token_asaas_1
ASAAS_LABEL_1=Elo Gestão Contábil
ASAAS_ENV_1=production

# Asaas — Conta 2
ASAAS_SECRET_2=seu_token_asaas_2
ASAAS_LABEL_2=Elo Gestão Empresarial
ASAAS_ENV_2=production

# Backend
BACKEND_URL=http://localhost:8000
BACKEND_SECRET=sua_senha_secreta
SYNC_HORARIO=06:30
SQLITE_DB_PATH=sistema_estrategico.db

# Inter Empresas (opcional)
INTER_CLIENT_ID=seu_client_id
INTER_CLIENT_SECRET=seu_client_secret
INTER_CERT_BASE64=certificado_em_base64
INTER_CERT_PASSWORD=senha_do_pfx
INTER_ACCOUNT=numero_conta
